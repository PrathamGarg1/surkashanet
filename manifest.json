{
  "manifest_version": 3,
  "name": "SurakshaNet",
  "version": "1.0.0",
  "description": "Privacy-first gender-based harassment detection.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.instagram.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_popup": "src/popup/evidence_viewer.html",
    "default_title": "SurakshaNet Evidence Manager"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.instagram.com/*"
      ],
      "js": [
        "src/content/index.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "assets/models/*",
        "assets/models/custom-macd-model/*",
        "assets/models/custom-macd-model/onnx/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}